{
  "name": "resourceos",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:electron": "npm run build && node scripts/prepare-electron.js && electron-builder"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cookies-next": "^4.1.1",
    "jose": "^5.2.0",
    "lucide-react": "latest",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "fs-extra": "^11.2.0",
    "prisma": "^6.0.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.resourceos.app",
    "productName": "ResourceOS Command Center",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      ".next/standalone/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma/dev.db",
        "to": ".next/standalone/prisma/dev.db"
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.exe",
      "**/*.dll"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
